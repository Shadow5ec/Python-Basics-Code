## PART 12: ASYNC EXECUTION

### Run Multiple Commands in Parallel

```python
import subprocess
import threading

def run_parallel(commands):
    processes = []
    
    # Start all processes
    for cmd in commands:
        p = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        processes.append(p)
    
    # Wait for all to complete
    results = []
    for p in processes:
        stdout, stderr = p.communicate()
        results.append({'stdout': stdout, 'stderr': stderr, 'returncode': p.returncode})
    
    return results

commands = [
    ['nmap', '192.168.1.1'],
    ['ping', '-c', '4', '8.8.8.8'],
    ['dig', 'example.com']
]

results = run_parallel(commands)
for r in results:
    print(r['stdout'])
```

